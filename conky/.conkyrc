conky.config = {
	background=true,
	update_interval=5,
	double_buffer=true,
	no_buffers=true,
	imlib_cache_size=10,
	draw_shades=false,
	draw_outline=false,
	draw_borders=false,
	gap_x=20,
	gap_y=10,
	alignment="top_left",
	minimum_height=400,
	minimum_width=0,
	own_window=true,
	own_window_type="dock",
	own_window_transparent=true,
	own_window_hints="undecorated,below,sticky,skip_taskbar,skip_pager",
	own_window_argb_visual=true,
	own_window_argb_value=0,
	use_xft=true,
	xftalpha=1,
	font="Hack:size=15",
	text_buffer_size=256,
	override_utf8_locale=true,
	default_color='FFFFFF',
	color0='FFB000',
	color1='33FF00',
}

conky.text = [[
${voffset 0}
${font}${color1}${time %A}${alignr}${time %F}\
${voffset 0}
${font Digital\-7:weight=Normal:size=100}${color0}${alignr}${time %I:%M%p}\
${voffset -45}
${font Hack:weight=Normal:size=15}${color1}${wireless_essid wlp0s29u1u5}(${wireless_link_qual_perc wlp0s29u1u5}%): ${alignr 18}${font FontAwesome:size=15} ${font Hack:weight=Normal:size=15}${downspeedf wlp0s29u1u5} KB/s${alignr}${font FontAwesome:size=15} ${font Hack:weight=Normal:size=15}${upspeedf wlp0s29u1u5} KB/s\
${voffset 0}
${font Hack:weight=Normal:size=15}${color1}Sacco.me:${alignr}${if_match ${execi 300 /usr/bin/ping -qc1 sacco.me > /dev/null 2>&1; echo "$?"} < 1}${execi 300 host -t A sacco.me | cut -d" " -f4}${else}Down${endif}
]]
