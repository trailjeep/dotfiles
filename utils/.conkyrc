conky.config = {

-------------------------------------
--  Generic Settings
-------------------------------------
background=true,
update_interval=1,
double_buffer=true,
no_buffers=true,
imlib_cache_size=0,

draw_shades=false,
draw_outline=false,
draw_borders=false,
draw_graph_borders=false,

-------------------------------------
--  Window Specifications
-------------------------------------
gap_x=20,
gap_y=0,

alignment="top_left",

minimum_height=600,
minimum_width=220,
maximum_width=220,

own_window=true,
own_window_type="dock",
own_window_transparent=true,
own_window_hints="undecorated,below,sticky,skip_taskbar,skip_pager",

own_window_argb_visual=true,
own_window_argb_value=0,

-------------------------------------
--  Text Settings
-------------------------------------
use_xft=true,
xftalpha=1,
font="Droid Sans:size=10",
text_buffer_size=256,
override_utf8_locale=true,

-------------------------------------
--  Color Scheme
-------------------------------------
default_color='CCCCCC',
color0='FFB000', -- clock
color1='CCCCCC', -- date
color2='CCCCCC', -- current temperature
color3='E18700', -- high tempratures
color4='00FFFF', -- low tempratures
color5='CCCCCC', -- days

-------------------------------------
-- font
-------------------------------------

font="Cascadia Code:size=10",
font2="SF Mono:size=10",
font3="FontAwesome:size=10",

-------------------------------------
--  Icon Sources
-------------------------------------
template0='~/.conky-vision/#fff__32',  --  today
template1='~/.conky-vision/#fff__32',  --  +1day
template2='~/.conky-vision/#fff__32',  --  +2days
template3='~/.conky-vision/#fff__32',  --  +3days
template4='~/.conky-vision/#fff__32',  --  +4days

-------------------------------------
--  API Key
-------------------------------------
template6="1e0721f8b94d3ee49f351a75a4c7abc8",

-------------------------------------
--  City ID
-------------------------------------
template7="4835512",

-------------------------------------
--  Temp Unit (default, metric, imperial)
-------------------------------------
template8="imperial",

-------------------------------------
--  Locale (e.g. "es_ES.UTF-8")
--  Leave empty for default
-------------------------------------
template9=""

}

conky.text = [[
\
${execi 300 ~/.conky-vision/get_weather ${template6} ${template7} ${template8} ${template9}}\
\
# Date
\
${font}${color1}${voffset 20}\
${execi 300 LANG=${template9} LC_TIME=${template9} date +"%A,"}\
${alignr}${execi 300 LANG=${template9} LC_TIME=${template9} date +"%F"}
\
# Time
\
${font Digital\-7:weight=Light:size=58}${color0}\
${time %I}${blink :}${time %M}\
${font Digital\-7:weight=Light:size=29}${color0}\
${alignr}${voffset -23}${time %P}
\
# Wx
\
${font}${color5}${voffset 35}\
${goto 25}${execi 300 LANG=${template9} LC_TIME=${template9} date +%a | gawk '{print toupper($0);}'}\
${goto 104}${execi 300 LANG=${template9} LC_TIME=${template9} date -d +1day +%a | gawk '{print toupper($0);}'}\
${goto 175}${execi 300 LANG=${template9} LC_TIME=${template9} date -d +2days +%a | gawk '{print toupper($0);}'}\
${color}
\
${execi 300 cp -f ${template0}/$(jq .weather[0].id ~/.cache/conky-vision/weather.json).png ~/.cache/conky-vision/current.png}${image ~/.cache/conky-vision/current.png -p 12,130 -s 40x40}\
${execi 300 cp -f ${template1}/$(~/.conky-vision/parse_weather 'first' '.weather[0].id' '1').png ~/.cache/conky-vision/forecast-1.png}${image ~/.cache/conky-vision/forecast-1.png -p 92,130  -s 40x40}\
${execi 300 cp -f ${template2}/$(~/.conky-vision/parse_weather 'first' '.weather[0].id' '2').png ~/.cache/conky-vision/forecast-2.png}${image ~/.cache/conky-vision/forecast-2.png -p 162,130  -s 40x40}
\
${font Cascadia Code:size=14:bold}${color2}\
${voffset 20}${goto 22}\
${execi 300 jq .main.temp ~/.cache/conky-vision/weather.json | awk '{print int($1+0.5)}' # round num}°\
${font}${voffset -3}${goto 92}\
${color4}${execi 300 ~/.conky-vision/parse_weather 'min' '.main.temp' '1'}°\
${color}|\
${color3}${execi 300 ~/.conky-vision/parse_weather 'max' '.main.temp' '1'}°\
${goto 162}\
${color4}${execi 300 ~/.conky-vision/parse_weather 'min' '.main.temp' '2'}°\
${color}|\
${color3}${execi 300 ~/.conky-vision/parse_weather 'max' '.main.temp' '2'}°\
${color}
\
# CPU
\
${voffset 20}\
${cpugraph 0 16,220 CCCCCC CCCCCC -l}
${font}CPU:${alignr}${cpu cpu0}%
\
# RAM
\

${memgraph 16,220 CCCCCC CCCCCC -l}
RAM:${alignr}${memperc}%
\
# Disk
\

${diskiograph 16,220 CCCCCC CCCCCC -l}
Disk I/O:${alignr}${diskio}
\
# Net
\

${upspeedgraph wlan0 16,90 CCCCCC CCCCCC}${alignr}${downspeedgraph wlan0 16,90 CCCCCC CCCCCC}
${upspeed wlan0}\
${goto 83}${font FontAwesome:size=10}${font} NET ${font FontAwesome:size=10}${font}\
${alignr}${downspeed wlan0}
\
# WiFi
\

${color1}${font FontAwesome:size=10}${color}${font} ${wireless_essid wlan0}\
${alignr -5}${wireless_link_qual_perc wlan0}% ${color1}${font FontAwesome:size=10}${color}${font}

${addr wlan0}\
${alignr}${if_match ${execi 300 /usr/bin/ping -qc1 sacco.me > /dev/null 2>&1; echo "$?"} < 1}${alignr}${color1}${else}${color red}${font} Down${alignr}${color1}${endif}${color}${font} ${execi 300 host -t A sacco.me | cut -d" " -f4}
\
]]
