conky.config = {
	background=true,
	update_interval=5,
	double_buffer=true,
	no_buffers=true,
	imlib_cache_size=10,
	draw_shades=false,
	draw_outline=true,
	draw_borders=false,
	gap_x=20,
	gap_y=20,
	alignment="top_left",
	minimum_height=250,
	minimum_width=400,
	own_window=true,
	own_window_type="dock",
	own_window_transparent=true,
	own_window_title="conky",
	own_window_transparent=true,
	own_window_hints="undecorated,below,sticky,skip_taskbar,skip_pager",
	own_window_argb_visual=true,
	own_window_argb_value=0,
	use_xft=true,
	xftalpha=1,
	font="Hack:size=12",
	text_buffer_size=256,
	override_utf8_locale=true,
	default_color='lightgrey',
	default_outline_color='black',
	-- time
	color0='FFB000',
	-- icons
	color1='aqua',
	-- hr was darkgrey
	color2='aqua',
}

conky.text = [[
${color1}${font FontAwesome:size=12}${color}${font} ${time %A},${alignr}${time %F} ${alignr}${color1}${font FontAwesome:size=12}
${voffset -15}
${color2}${font}${hr}
${voffset -15}
${color0}${font Digital\-7:weight=Normal:size=85}${alignc}${time %I:%M%P}
${voffset -105}
${color2}${font}${hr}
${voffset -12}
${color1}${font FontAwesome:size=12}${color}${font} ${wireless_essid wlp0s29u1u5}${alignr}${upspeedf wlp0s29u1u5} KB/s ${alignr}${color1}${font FontAwesome:size=12}
${voffset -12}
${color1}${font FontAwesome:size=12}${color}${font} ${wireless_link_qual_perc wlp0s29u1u5}%${alignr}${font}${downspeedf wlp0s29u1u5} KB/s ${alignr}${color1}${font FontAwesome:size=12}
${voffset -12}
${color1}${font FontAwesome:size=12}${color}${font} Sacco.me${alignr}${if_match ${execi 300 /usr/bin/ping -qc1 sacco.me > /dev/null 2>&1; echo "$?"} < 1}${color}${font}${execi 300 host -t A sacco.me | cut -d" " -f4} ${alignr}${color1}${font FontAwe some:size=12}${else}${color red}${font}Down ${alignr}${color1}${font FontAwesome:size=12}${endif}
]]
