conky.config = {

-------------------------------------
--  Generic Settings
-------------------------------------
background=true,
update_interval=1,
double_buffer=true,
no_buffers=true,
imlib_cache_size=0,

-------------------------------------
--  Window Specifications
-------------------------------------
gap_x=20,
gap_y=20,
alignment="top_left",
--minimum_size="x,y",
minimum_height=650,
minimum_width=220,
maximum_width=220,
own_window=true,
own_window_class="conky",
own_window_type="dock",
own_window_transparent=true,
own_window_hints="undecorated,below,sticky,skip_taskbar,skip_pager,below",
own_window_argb_visual=true,
own_window_argb_value=0,
border_inner_margin=6,
border_outer_margin=0,

-------------------------------------
--  Graphics Settings
-------------------------------------
draw_shades=false,
default_shade_color="AAAAAA",
draw_outline=false,
default_outline_color="AAAAAA",
draw_borders=false,
draw_graph_borders=false,
show_graph_scale=false,
show_graph_range=false,

-------------------------------------
--  Text Settings
-------------------------------------
use_xft=true,
xftalpha=1,
font="Droid Sans:size=10",
text_buffer_size=256,
override_utf8_locale=true,
format_human_readable=true,

-------------------------------------
--  Useful shortenings
-------------------------------------
short_units=true,
pad_percents=2,
top_name_width=30,

-------------------------------------
--  Color Scheme
-------------------------------------
default_color='34be5b', -- manjaro green
color0='ffa500', -- clock
color1='E18700', -- high tempratures
color2='00FFFF', -- low tempratures
color3='0A95BE', -- graphs/glyphs

-------------------------------------
-- font
-------------------------------------
font="Cascadia Code:size=10",
font0="Cascadia Code:size=14", -- date
font1="Cascadia Code:size=2.5", -- logo
font2="FontAwesome:size=10", -- glyphs
font3="Digital\\-7:weight=Light:size=58", -- clock
font4="Digital\\-7:weight=Light:size=29", -- clock am/pm
font5="Cascadia Code:size=18:weight=bold",

-------------------------------------
--  Icon Sources
-------------------------------------
template0='~/.conky-vision/#bbb__56',  --  today
template1='~/.conky-vision/#bbb__40',  --  +1day
template2='~/.conky-vision/#bbb__40',  --  +2days
template3='~/.conky-vision/#bbb__40',  --  +3days
template4='~/.conky-vision/#bbb__40',  --  +4days

-------------------------------------
--  API Key
-------------------------------------
template6="1e0721f8b94d3ee49f351a75a4c7abc8",

-------------------------------------
--  City ID
-------------------------------------
template7="4835512",

-------------------------------------
--  Temp Unit (default, metric, imperial)
-------------------------------------
template8="imperial",

-------------------------------------
--  Locale (e.g. "es_ES.UTF-8")
--  Leave empty for default
-------------------------------------
template9=""

}

conky.text = [[
\
${execi 300 ~/.conky-vision/get_weather ${template6} ${template7} ${template8} ${template9}}\
\
# Date
\
${font0}${color}\
${execi 300 LANG=${template9} LC_TIME=${template9} date +"%A"}\
${alignr}${execi 300 LANG=${template9} LC_TIME=${template9} date +"%F"}
\
# Time
\
${font3}${color0}\
${time %I}${blink :}${time %M}\
${font4}${color0}\
${alignr}${voffset 0}${time %P}
\
# Wx
\
${font}${color}${voffset 10}\
${execi 300 cp -f ${template0}/$(jq .weather[0].id ~/.cache/conky-vision/weather.json).png ~/.cache/conky-vision/current.png}${image ~/.cache/conky-vision/current.png -p 0,95 -s 56x56}\
${voffset 7}$font5}${goto 70}${execi 300 jq .main.temp ~/.cache/conky-vision/weather.json | awk '{print int($1+0.5)}' # round num}°${font}\
#${voffset -15}${alignr}${execi 300 jq -r .name ~/.cache/conky-vision/weather.json}
${voffset -13}\
${alignr}${execi 300 jq -r .weather[0].description ~/.cache/conky-vision/weather.json}
${alignr}${execi 300 jq -r .weather[1].description ~/.cache/conky-vision/weather.json}

${execi 300 LANG=${template9} LC_TIME=${template9} date -d +1day +%a | gawk '{print toupper($0);}'}\
${alignc -13}${execi 300 LANG=${template9} LC_TIME=${template9} date -d +2day +%a | gawk '{print toupper($0);}'}\
${alignr}${execi 300 LANG=${template9} LC_TIME=${template9} date -d +3days +%a | gawk '{print toupper($0);}'}\

\
${execi 300 cp -f ${template1}/$(~/.conky-vision/parse_weather 'first' '.weather[0].id' '1').png ~/.cache/conky-vision/forecast-1.png}${image ~/.cache/conky-vision/forecast-1.png -p 0,173   -s 40x40}\
${execi 300 cp -f ${template2}/$(~/.conky-vision/parse_weather 'first' '.weather[0].id' '2').png ~/.cache/conky-vision/forecast-1.png}${image ~/.cache/conky-vision/forecast-1.png -p 92,173  -s 40x40}\
${execi 300 cp -f ${template3}/$(~/.conky-vision/parse_weather 'first' '.weather[0].id' '3').png ~/.cache/conky-vision/forecast-2.png}${image ~/.cache/conky-vision/forecast-2.png -p 180,173  -s 40x40}
\
${font}${color}\
${voffset 20}\
${color2}${execi 300 ~/.conky-vision/parse_weather 'min' '.main.temp' '1'}°\
${color}|\
${color1}${execi 300 ~/.conky-vision/parse_weather 'max' '.main.temp' '1'}°\
${font}${alignc -30}\
${color2}${execi 300 ~/.conky-vision/parse_weather 'min' '.main.temp' '2'}°\
${color}|\
${color1}${execi 300 ~/.conky-vision/parse_weather 'max' '.main.temp' '2'}°\
${alignr}\
${color2}${execi 300 ~/.conky-vision/parse_weather 'min' '.main.temp' '3'}°\
${color}|\
${color1}${execi 300 ~/.conky-vision/parse_weather 'max' '.main.temp' '3'}°\
${color}
\
# CPU
\
${voffset 10}\
${cpugraph 1 20,95 0A95BE 0A95BE -l}${alignr}${cpugraph 2 20,95 0A95BE 0A95BE -l}
${voffset -7}\
${cpu cpu1}%\
${goto 70}CPU1\
${goto 125}CPU2\
${alignr}${cpu cpu2}%
\
${voffset 10}\
${cpugraph 3 20,95 0A95BE 0A95BE -l}${alignr}${cpugraph 4 20,95 0A95BE 0A95BE -l}
${voffset -7}\
${cpu cpu3}%\
${goto 70}CPU3\
${goto 125}CPU4\
${alignr}${cpu cpu4}%
\
# RAM / SWAP
\

${color3}${membar 10,95}${alignr}${swapbar 10,95}${color}
${voffset -2}\
${memperc}%${goto 80}RAM${goto 130}SWAP${alignr}${swapperc}%
\
# Disk I/O / Usage
\
${voffset 5}\
${diskiograph 20,95 0A95BE 0A95BE -l}${voffset 14}${alignr}${color3}${fs_bar 10,95 /}${color}
${voffset -20}\
${diskio}${goto 77}I/O HD ${fs_type /}${alignr}${fs_used_perc /}%
\
# Net
\
${voffset 5}\
${upspeedgraph wlan0 20,90 0A95BE 0A95BE}${alignr}${downspeedgraph wlan0 20,90 0A95BE 0A95BE}
${voffset -7}\
${upspeed wlan0}\
${goto 83}${color3}${font2}${color}${font} NET ${color3}${font2}${color}${font}\
${alignr}${downspeed wlan0}
\
# WiFi
\

${color3}${font2}${color}${font} ${wireless_essid wlan0}\
${alignr 0}${wireless_link_qual_perc wlan0}% ${color3}${font2}${color}${font}
${addr wlan0}\
${if_match ${execi 300 /usr/bin/ping -qc1 sacco.me > /dev/null 2>&1; echo "$?"} < 1}${alignr}${color}${else}${color red}${font} Down${alignr}${color}${endif}${color}${font} ${execi 300 host -t A sacco.me | cut -d" " -f4}
\
# Distro
\
${voffset 5}\
${color}\
${font1}${execi 10000 screenfetch -LN }\
${voffset -72}${alignr}${font}${nodename}
${voffset 2}${alignr}${font}${execi 10000 awk -F= '/TION/ {print $2}' /etc/lsb-release |sed 's/"//g'}
${voffset 2}$alignr${execi 10000 awk -F= '/EASE=/ {printf $2" "} /NAME/ {print $2}' /etc/lsb-release}
${voffset 2}$alignr${kernel}
\
]]
