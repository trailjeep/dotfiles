[Event/criticalbattery]
Execute=
Logfile=
Sound=/usr/share/sounds/deepin/stereo/power-unplug-battery-low.wav
TTS=

[Event/fullbattery]
Action=Sound
Execute=
Logfile=
Sound=/usr/share/sounds/deepin/stereo/audio-volume-change.wav
TTS=

[Event/lowbattery]
Execute=
Logfile=
Sound=/usr/share/sounds/deepin/stereo/power-unplug-battery-low.wav
TTS=

[Event/lowperipheralbattery]
Execute=
Logfile=
Sound=/usr/share/sounds/deepin/stereo/power-unplug-battery-low.wav
TTS=

[Event/pluggedin]
Action=Sound
Execute=
Logfile=
Sound=/usr/share/sounds/deepin/stereo/power-plug.wav
TTS=

[Event/powerdevilerror]
Execute=
Logfile=
Sound=/usr/share/sounds/deepin/stereo/dialog-error-critical.wav
TTS=

[Event/unplugged]
Execute=
Logfile=
Sound=/usr/share/sounds/deepin/stereo/power-unplug.wav
TTS=
