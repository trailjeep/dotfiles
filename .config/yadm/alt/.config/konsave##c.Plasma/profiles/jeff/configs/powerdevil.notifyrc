TTS=

[Event/lowbattery]
Execute=
Logfile=
Sound=/home/jeff/.local/share/sounds/zorin/stereo/dialog-warning.ogg
TTS=

[Event/lowperipheralbattery]
Execute=
Logfile=
Sound=/home/jeff/.local/share/sounds/zorin/stereo/dialog-warning.ogg
TTS=

[Event/pluggedin]
Action=Sound
Execute=
Logfile=
Sound=/home/jeff/.local/share/sounds/zorin/stereo/success.ogg
TTS=

[Event/powerdevilerror]
